NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/khidmashop?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-minimum-32-characters-long
JWT_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# SMS - Twilio (Remplacez par vos vraies clés)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_128_character_auth_token_here
TWILIO_FROM_PHONE=+15017122661

# OTP
OTP_EXPIRATION_MINUTES=5
OTP_LENGTH=6

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudinary (optionnel)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

LOG_LEVEL=debug

