# Application
NODE_ENV=development
PORT=3001
APP_NAME=KhidmaShop API

# Database
DATABASE_URL=postgresql://db_user:db_password@localhost:5432/khidmashop?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars
JWT_EXPIRATION=900 # 15 minutes in seconds
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-at-least-32-chars
JWT_REFRESH_EXPIRATION=1296000 # 15 days in seconds

# SMS / Vonage
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret
VONAGE_FROM=KhidmaShop
OTP_EXPIRATION_MINUTES=5
OTP_LENGTH=6

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=khidma-shop
